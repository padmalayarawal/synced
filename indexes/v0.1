<!-- Synced V0.1 -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Synced</title>
    <style>
        /* This section controls how the page looks */
        body {
            background-color: #1a1a1a; /* Dark grey background */
            color: #ffffff; /* White text */
            font-family: 'Courier New', Courier, monospace; /* Timer-style font */
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh; /* Full screen height */
            margin: 0;
        }

        h1 {
            font-size: 2rem;
            margin-bottom: 20px;
            font-weight: normal;
        }

        #timer {
            font-size: 11rem; /* Make the numbers huge */
            font-weight: bold;
            background-color: #333;
            padding: 20px 40px;
            border-radius: 10px;
            box-shadow: 0 0 20px rgba(0,0,0,0.5);
        }

        .label {
            margin-top: 10px;
            color: #aaaaaa;
        }
    </style>
</head>
<body>

    <h1>Next Reset In:</h1>
    <div id="timer">Loading...</div>
    <div class="label">The best present of life is PRESENT :)</div>

    <script>
        /* This section controls the logic/math */
        function updateTimer() {
            // 1. Get the current time
            const now = new Date();

            // 2. Set the target time to tomorrow at 00:00:00
            const tomorrow = new Date(now);
            tomorrow.setHours(24, 0, 0, 0);

            // 3. Calculate the difference in milliseconds
            const diff = tomorrow - now;

            // 4. Calculate hours, minutes, and seconds from the difference
            const hours = Math.floor(diff / (1000 * 60 * 60));
            const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
            const seconds = Math.floor((diff % (1000 * 60)) / 1000);

            // 5. Add a "0" in front if the number is less than 10 (e.g., "05" instead of "5")
            const h = hours < 10 ? "0" + hours : hours;
            const m = minutes < 10 ? "0" + minutes : minutes;
            const s = seconds < 10 ? "0" + seconds : seconds;

            // 6. Display the result in the HTML element with id="timer"
            document.getElementById("timer").innerText = `${h}:${m}:${s}`;
        }

        // Run the function immediately, then update it every 1000 milliseconds (1 second)
        updateTimer();
        setInterval(updateTimer, 1000);
    </script>

</body>
</html>
